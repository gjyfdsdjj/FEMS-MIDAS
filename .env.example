# .env.example
# 실제 사용 시 .env 파일로 복사 후 값 채우기
# .env 는 .gitignore에 반드시 포함

# --- 데이터베이스 ---
DATABASE_URL=postgresql+asyncpg://user:password@rds-endpoint:5432/midas

# --- MQTT ---
MQTT_HOST=ec2-xx-xx-xx-xx.compute.amazonaws.com
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# --- Telegram 알림 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- JWT 인증 ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- 기상청 API ---
KMA_API_KEY=
KMA_API_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst

# --- Edge 노드 식별 (RPi에서만 설정) ---
NODE_ID=node_A
FACTORY_IDS=1,2

# --- Streamlit 프론트 ---
API_BASE_URL=http://localhost:8000
