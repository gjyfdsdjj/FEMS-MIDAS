# .env.example
# 실제 사용 시 .env 파일로 복사 후 값 채우기
# .env 는 .gitignore에 반드시 포함

# --- 데이터베이스 ---
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# --- MQTT ---
# 로컬 개발 시 백엔드 PC IP (백엔드와 같은 PC면 localhost)
# RPi5에서 실행 시 백엔드 PC의 로컬 IP 입력 (예: 192.168.0.10)
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# --- Telegram 알림 ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- JWT 인증 ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- 기상청 API ---
KMA_API_KEY=
KMA_API_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst

# --- Edge 노드 식별 (RPi에서만 설정) ---
NODE_ID=node_A
FACTORY_IDS=1

# --- Streamlit 프론트 ---
API_BASE_URL=http://localhost:8000

# --- Peltier control on Raspberry Pi ---
PELTIER_ENABLED=true
PELTIER_FACTORY_ID=1
PELTIER_RPWM_PIN=18
PELTIER_LPWM_PIN=19
PELTIER_REN_PIN=20
PELTIER_LEN_PIN=21
PELTIER_FAN_PIN=23
PELTIER_PWM_HZ=1000
PELTIER_FAN_ACTIVE_LOW=false
PELTIER_FAN_SPINUP_SECONDS=2.0
PELTIER_FAN_COOLDOWN_SECONDS=30.0
PELTIER_MAX_DUTY=50.0
